<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF121212"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model Plugin"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- Model Plugin Info -->
        <TextView
            android:id="@+id/txtDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtDetailUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtDetailStream"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtDetailTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Upload .gguf section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model File (.gguf)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#BBBBBB"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUploadGguf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select .gguf File"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF333333"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtCurrentModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Config Headers Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Config Headers"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#BBBBBB"
                android:layout_centerVertical="true"/>

            <ImageButton
                android:id="@+id/btnAddHeader"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_input_add"
                android:background="@drawable/icon_circle_bg"
                android:contentDescription="Add header"
                app:tint="#FFFFFF" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHeaders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"
            android:paddingBottom="16dp"/>

        <Button
            android:id="@+id/btnSaveHeaders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Headers"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF333333"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
