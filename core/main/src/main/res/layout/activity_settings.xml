<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF121212"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- Local LLM Upload -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuLocalLLM"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Model Plugin -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuModelPlugin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Skills -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Public Tools -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuPublicTools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Formatter Plugin -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuFormatterPlugin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Memory Plugin -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuMemoryPlugin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- LlamaCpp -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuLlamaCpp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Access Terminal -->
        <include layout="@layout/settings_menu_item"
            android:id="@+id/menuAccessTerminal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Start SSH Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:background="#1E1E1E">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SSH Server"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start or stop the SSH server"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switchSsh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
